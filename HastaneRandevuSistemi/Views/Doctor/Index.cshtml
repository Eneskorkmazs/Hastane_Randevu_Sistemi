@model IEnumerable<HastaneRandevuSistemi.Models.Doctor>

@{
    ViewData["Title"] = "Doktor Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary">
                <i class="fa-solid fa-user-doctor me-2"></i> Doktor Listesi
            </h2>
            <p class="text-muted mb-0">Sistemde kayıtlı tüm doktorlar ve branşları.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm rounded-pill px-4">
            <i class="fa fa-plus me-2"></i> Yeni Doktor
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="py-3 ps-4" style="min-width: 250px;">Doktor Bilgileri</th>
                        <th>Poliklinik / Branş</th>
                        <th class="text-end pe-4" style="width: 150px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center py-2">
                                    @* Profil İkonu / İsmin İlk Harfi *@
                                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold me-3 border border-primary border-opacity-25 shadow-sm" style="width: 48px; height: 48px; min-width: 48px;">
                                        @(item.Name.Length > 0 ? item.Name.Substring(0, 1).ToUpper() : "D")
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark fs-6 lh-sm">
                                            @* Ünvan zaten Name içinde olduğu için sadece Name ve Surname basıyoruz *@
                                            @item.Name @item.Surname
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-white text-primary border border-primary border-opacity-25 px-3 py-2 rounded-pill shadow-sm">
                                    <i class="fa-solid fa-hospital me-1 text-primary text-opacity-75"></i>
                                    @item.Department?.Name
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-pill bg-white border p-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-link text-warning px-3" title="Düzenle">
                                        <i class="fa-solid fa-pen-to-square fa-lg"></i>
                                    </a>
                                    <div class="vr my-2 opacity-25" style="width: 1px;"></div>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-link text-danger px-3" title="Sil">
                                        <i class="fa-solid fa-trash-can fa-lg"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>