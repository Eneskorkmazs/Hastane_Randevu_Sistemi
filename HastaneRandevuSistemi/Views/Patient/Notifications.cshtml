@model IEnumerable<HastaneRandevuSistemi.Models.Notification>

@{
    ViewData["Title"] = "Bildirimler";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <span class="eyebrow text-primary">Bildirim Merkezi</span>
            <h1 class="h3 fw-bold mb-1">Hasta Bildirimleri</h1>
            <p class="text-muted mb-0">Randevu hareketleri ve profil güncellemeleri burada listelenir.</p>
        </div>

        <form asp-action="MarkAllAsRead" method="post">
            <button type="submit" class="btn btn-outline-primary rounded-pill px-4">
                <i class="fa-solid fa-check-double me-2"></i>Tümünü Okundu İşaretle
            </button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <div class="empty-state">
                    <i class="fa-regular fa-bell-slash"></i>
                    <p class="mb-0">Henüz bildiriminiz bulunmuyor.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="notification-stack">
            @foreach (var item in Model)
            {
                <div class="notification-card large @(item.IsRead ? "is-read" : "is-unread")">
                    <div class="d-flex justify-content-between gap-3 flex-wrap">
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge rounded-pill bg-light text-dark border">@item.Type</span>
                                <strong>@item.Title</strong>
                            </div>
                            <p class="mb-2 text-muted">@item.Message</p>
                            <div class="small text-muted">@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>

                        <div class="d-flex align-items-start gap-2">
                            @if (!string.IsNullOrWhiteSpace(item.Link))
                            {
                                <a href="@item.Link" class="btn btn-sm btn-light rounded-pill">İlgili Sayfa</a>
                            }
                            @if (!item.IsRead)
                            {
                                <form asp-action="MarkAsRead" method="post">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary rounded-pill">Okundu</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .eyebrow {
        display: inline-block;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }

    .notification-stack {
        display: grid;
        gap: 1rem;
    }

    .notification-card {
        border-radius: 20px;
        padding: 1rem 1.1rem;
        background: #fff;
        border: 1px solid #edf1f5;
    }

    .notification-card.large {
        padding: 1.25rem 1.35rem;
    }

    .notification-card.is-unread {
        border-color: #b8ddff;
        background: linear-gradient(180deg, #f8fcff 0%, #eef7ff 100%);
    }

    .notification-card.is-read {
        opacity: 0.85;
    }

    .empty-state {
        min-height: 180px;
        display: grid;
        place-items: center;
        text-align: center;
        color: #7d8a97;
        gap: 0.75rem;
    }

    .empty-state i {
        font-size: 2.5rem;
    }
</style>
