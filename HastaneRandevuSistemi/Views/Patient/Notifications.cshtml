@model IEnumerable<HastaneRandevuSistemi.Models.Notification>

@{
    ViewData["Title"] = "Bildirimler";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <span class="eyebrow text-primary">Bildirim Merkezi</span>
            <h1 class="h3 fw-bold mb-1">Hasta Bildirimleri</h1>
            <p class="text-muted mb-0">Randevu hareketleri ve profil guncellemeleri burada listelenir.</p>
        </div>

        <div class="d-flex align-items-center gap-2">
            <span id="notificationsUnreadBadge" class="badge rounded-pill bg-primary-subtle text-primary border border-primary px-3 py-2">Okunmamis: @unreadCount</span>

            <form id="markAllAsReadForm" asp-action="MarkAllAsReadAjax" method="post" class="notification-mark-all-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary rounded-pill px-4" @(unreadCount == 0 ? "disabled" : "")>
                    <i class="fa-solid fa-check-double me-2"></i>Tumunu Okundu Isaretle
                </button>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5">
                <div class="empty-state">
                    <i class="fa-regular fa-bell-slash"></i>
                    <p class="mb-0">Henüz bildiriminiz bulunmuyor.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="notification-stack">
            @foreach (var item in Model)
            {
                <div class="notification-card large @(item.IsRead ? "is-read" : "is-unread")">
                    <div class="d-flex justify-content-between gap-3 flex-wrap">
                        <div>
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge rounded-pill bg-light text-dark border">@item.Type</span>
                                @if (!item.IsRead)
                                {
                                    <span class="badge rounded-pill bg-primary text-white">Yeni</span>
                                }
                                <strong>@item.Title</strong>
                            </div>
                            <p class="mb-2 text-muted">@item.Message</p>
                            <div class="small text-muted">@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>

                        <div class="d-flex align-items-start gap-2">
                            @if (!string.IsNullOrWhiteSpace(item.Link))
                            {
                                <a href="@item.Link" class="btn btn-sm btn-light rounded-pill">Ilgili Sayfa</a>
                            }
                            @if (!item.IsRead)
                            {
                                <form asp-action="MarkAsReadAjax" method="post" class="notification-mark-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-primary rounded-pill">Okundu</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            const cards = document.querySelectorAll(".notification-card");
            const summaryBadge = document.getElementById("notificationsUnreadBadge");
            const headerBadge = document.getElementById("unreadNotificationBadge");
            const markAllForm = document.getElementById("markAllAsReadForm");
            const singleForms = document.querySelectorAll(".notification-mark-form");

            function setUnreadCount(count) {
                if (!summaryBadge) {
                    return;
                }

                summaryBadge.textContent = `Okunmamis: ${count}`;
                const markAllButton = markAllForm?.querySelector("button");
                if (markAllButton) {
                    markAllButton.disabled = count === 0;
                }

                if (headerBadge) {
                    headerBadge.textContent = String(count);
                    headerBadge.style.display = count > 0 ? "inline-flex" : "none";
                }
            }

            async function postAjax(form) {
                const formData = new URLSearchParams(new FormData(form));
                const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'RequestVerificationToken': token || ''
                    },
                    body: formData.toString(),
                    credentials: 'same-origin'
                });

                if (!response.ok) {
                    return null;
                }

                try {
                    return await response.json();
                } catch {
                    return null;
                }
            }

            function hideMarkAsReadButton(card) {
                const markForm = card.querySelector('.notification-mark-form');
                if (markForm) {
                    markForm.remove();
                }

                const badge = card.querySelector('.badge.rounded-pill.bg-primary.text-white');
                if (badge) {
                    badge.remove();
                }
                card.classList.remove('is-unread');
                card.classList.add('is-read');
            }

            singleForms.forEach(form => {
                form.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const card = form.closest('.notification-card');
                    const result = await postAjax(form);

                    if (!result || result.success !== true) {
                        window.location.reload();
                        return;
                    }

                    setUnreadCount(Number(result.unreadCount ?? 0));
                    if (card) {
                        hideMarkAsReadButton(card);
                    }
                });
            });

            if (markAllForm) {
                markAllForm.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const result = await postAjax(markAllForm);
                    if (!result || result.success !== true) {
                        window.location.reload();
                        return;
                    }

                    setUnreadCount(0);
                    cards.forEach(card => {
                        card.classList.remove('is-unread');
                        card.classList.add('is-read');
                        hideMarkAsReadButton(card);
                    });
                });
            }
        })();
    </script>
}

<style>
    .eyebrow {
        display: inline-block;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-weight: 700;
        margin-bottom: 0.75rem;
    }

    .notification-stack {
        display: grid;
        gap: 1rem;
    }

    .notification-card {
        border-radius: 20px;
        padding: 1rem 1.1rem;
        background: #fff;
        border: 1px solid #edf1f5;
    }

    .notification-card.large {
        padding: 1.25rem 1.35rem;
    }

    .notification-card.is-unread {
        border-color: #b8ddff;
        background: linear-gradient(180deg, #f8fcff 0%, #eef7ff 100%);
    }

    .notification-card.is-read {
        opacity: 0.85;
    }

    .empty-state {
        min-height: 180px;
        display: grid;
        place-items: center;
        text-align: center;
        color: #7d8a97;
        gap: 0.75rem;
    }

    .empty-state i {
        font-size: 2.5rem;
    }
</style>
