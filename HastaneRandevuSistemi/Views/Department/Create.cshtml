@model HastaneRandevuSistemi.Models.Department

@{
    ViewData["Title"] = "Yeni Poliklinik Ekle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <div class="card shadow-lg border-0 rounded-5 overflow-hidden">

                <div class="card-header text-white text-center py-5" style="background: linear-gradient(135deg, #004e92 0%, #000428 100%);">
                    <div class="position-relative mb-3">
                        <div class="bg-white bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 80px; height: 80px;">
                            <i class="fa-solid fa-hospital fa-3x text-info"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-0">Yeni Poliklinik Tanımla</h3>
                    <p class="text-white-50 small mt-2 mb-0">Hastaneye yeni bir birim veya branş ekleyin.</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 small mb-4 shadow-sm border-0"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control rounded-pill px-4 border-light bg-light focus-white" placeholder="Poliklinik Adı" required />
                            <label asp-for="Name" class="px-4 text-muted">
                                <i class="fa-solid fa-tag me-2 text-primary"></i>Poliklinik Adı (Örn: Kardiyoloji)
                            </label>
                            <span asp-validation-for="Name" class="text-danger small ms-3"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <textarea asp-for="Description" class="form-control rounded-4 px-4 border-light bg-light focus-white" placeholder="Açıklama" style="height: 120px"></textarea>
                            <label asp-for="Description" class="px-4 text-muted">
                                <i class="fa-solid fa-align-left me-2 text-primary"></i>Kısa Açıklama / Bilgi
                            </label>
                            <span asp-validation-for="Description" class="text-danger small ms-3"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow hover-grow py-3"
                                    style="background: linear-gradient(90deg, #004e92 0%, #000428 100%); border:none;">
                                <i class="fa-solid fa-circle-plus me-2"></i> Polikliniği Kaydet
                            </button>

                            <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none fw-semibold mt-2">
                                <i class="fa-solid fa-arrow-left me-2"></i> Listeye Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-4 p-3 rounded-4 bg-light border text-center shadow-sm">
                <small class="text-muted italic">
                    <i class="fa-solid fa-circle-info me-1 text-primary"></i>
                    Eklediğiniz poliklinikler doktor kayıt sayfasında otomatik olarak listelenecektir.
                </small>
            </div>

        </div>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}