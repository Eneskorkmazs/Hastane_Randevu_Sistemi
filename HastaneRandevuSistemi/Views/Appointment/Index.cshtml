@model IEnumerable<HastaneRandevuSistemi.Models.Appointment>

@{
    bool isHasta = User.IsInRole("Hasta");
    ViewData["Title"] = isHasta ? "Randevu Geçmişim" : "Randevu Listesi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-primary"><i class="fa-solid fa-calendar-check me-2"></i>@ViewData["Title"]</h2>
            <p class="text-muted mb-0">@(isHasta ? "Geçmiş ve yaklaşan tüm randevularınız." : "Onay bekleyen ve tamamlanan randevular.")</p>
        </div>
        <div class="d-flex gap-2">
            @if (isHasta)
            {
                <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-outline-primary rounded-pill px-4">Panele Dön</a>
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="fa fa-plus me-2"></i>Yeni Randevu
                </a>
            }
            else
            {
                <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm rounded-pill px-4">
                    <i class="fa fa-plus me-2"></i>Yeni Randevu
                </a>
            }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body py-5 text-center">
                <div class="text-muted mb-3"><i class="fa-regular fa-calendar-xmark fa-4x"></i></div>
                <h4>Kayıt bulunamadı.</h4>
            </div>
        </div>
    }
    else
    {
        <div class="d-md-none">
            @foreach (var item in Model)
            {
                var canPatientCancel = isHasta && item.AppointmentDate > DateTime.Now && item.Status != AppointmentStatus.Iptal && item.Status != AppointmentStatus.Tamamlandi;

                <div class="card shadow-sm mb-3 border-0 rounded-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                            <span class="fw-bold text-dark">@item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</span>
                            <span class="badge rounded-pill @(item.Status switch {
                                AppointmentStatus.Bekliyor => "bg-warning text-dark",
                                AppointmentStatus.Onaylandi => "bg-success",
                                AppointmentStatus.Iptal => "bg-danger",
                                _ => "bg-primary"
                            })">@item.Status</span>
                        </div>

                        <h5 class="card-title fw-bold text-primary">@item.Doctor?.Name @item.Doctor?.Surname</h5>
                        <p class="small text-muted mb-1">@item.Doctor?.Department?.Name</p>

                        <div class="d-grid gap-2 mt-3">
                            @if (canPatientCancel)
                            {
                                <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-pill">Randevuyu İptal Et</a>
                            }
                            else if (!isHasta)
                            {
                                @if (item.Status == AppointmentStatus.Bekliyor)
                                {
                                    <div class="btn-group w-100">
                                        <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-success">Onayla</a>
                                        <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-danger">Reddet</a>
                                    </div>
                                }
                                else if (item.Status == AppointmentStatus.Onaylandi)
                                {
                                    <div class="btn-group w-100">
                                        <a asp-action="Complete" asp-route-id="@item.Id" class="btn btn-primary">Tamamla</a>
                                        <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-outline-danger">İptal</a>
                                    </div>
                                }
                                else
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-secondary" onclick="return confirm('Bu kaydı kalıcı olarak silmek istediğinize emin misiniz?');">Sil</a>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-none d-md-block">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-secondary">
                            <tr>
                                <th class="py-3 ps-4">Tarih</th>
                                @if (!isHasta)
                                {
                                    <th>Hasta</th>
                                }
                                <th>Doktor</th>
                                <th>Durum</th>
                                <th class="text-end pe-4">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var canPatientCancel = isHasta && item.AppointmentDate > DateTime.Now && item.Status != AppointmentStatus.Iptal && item.Status != AppointmentStatus.Tamamlandi;

                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold d-block">@item.AppointmentDate.ToString("dd.MM.yyyy")</span>
                                        <span class="small text-muted">@item.AppointmentDate.ToString("HH:mm")</span>
                                    </td>
                                    @if (!isHasta)
                                    {
                                        <td>@item.PatientName @item.PatientSurname</td>
                                    }
                                    <td>
                                        <span class="fw-bold d-block">@item.Doctor?.Name @item.Doctor?.Surname</span>
                                        <span class="badge bg-light text-secondary border">@item.Doctor?.Department?.Name</span>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill @(item.Status switch {
                                            AppointmentStatus.Bekliyor => "bg-warning text-dark",
                                            AppointmentStatus.Onaylandi => "bg-success",
                                            AppointmentStatus.Iptal => "bg-danger",
                                            _ => "bg-primary"
                                        })">@item.Status</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (canPatientCancel)
                                        {
                                            <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill">İptal Et</a>
                                        }
                                        else if (!isHasta)
                                        {
                                            @if (item.Status == AppointmentStatus.Bekliyor)
                                            {
                                                <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-sm btn-success" title="Onayla"><i class="fa-solid fa-check"></i></a>
                                                <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Reddet"><i class="fa-solid fa-xmark"></i></a>
                                            }
                                            else if (item.Status == AppointmentStatus.Onaylandi)
                                            {
                                                <a asp-action="Complete" asp-route-id="@item.Id" class="btn btn-sm btn-primary" title="Tamamla"><i class="fa-solid fa-clipboard-check"></i></a>
                                                <a asp-action="Cancel" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="İptal"><i class="fa-solid fa-ban"></i></a>
                                            }
                                            else
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-light text-danger" title="Sil" onclick="return confirm('Bu kaydı silmek istediğinize emin misiniz?');">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </a>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
