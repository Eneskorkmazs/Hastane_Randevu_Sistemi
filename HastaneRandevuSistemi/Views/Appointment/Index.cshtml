@model IEnumerable<HastaneRandevuSistemi.Models.Appointment>

@{
    bool isHasta = User.IsInRole("Hasta");
    ViewData["Title"] = isHasta ? "Randevu Gecmisim" : "Randevu Listesi";
    var statusOptions = ViewData["StatusOptions"] as IEnumerable<SelectListItem>;
    var doctorOptions = ViewData["DoctorOptions"] as IEnumerable<SelectListItem>;
    var selectedStatus = ViewData["SelectedStatus"]?.ToString();
    var searchTerm = ViewData["SearchTerm"] as string;
    var selectedDoctorId = ViewData["DoctorId"] as int?;
    var fromDate = ViewData["FromDate"] as string;
    var toDate = ViewData["ToDate"] as string;
    var today = DateTime.Today;
    var todayText = today.ToString("yyyy-MM-dd");
    var next7Text = today.AddDays(7).ToString("yyyy-MM-dd");
    var next30Text = today.AddDays(30).ToString("yyyy-MM-dd");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-primary"><i class="fa-solid fa-calendar-check me-2"></i>@ViewData["Title"]</h2>
            <p class="text-muted mb-0">@(isHasta ? "Gecmis ve yaklasan tum randevulariniz." : "Randevulari filtreleyip yonetin.")</p>
        </div>
        <div class="d-flex gap-2">
            @if (isHasta)
            {
                <a asp-controller="Patient" asp-action="Dashboard" class="btn btn-outline-primary rounded-pill px-4">Panele Don</a>
            }
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="fa fa-plus me-2"></i>Yeni Randevu
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Durum</label>
                    <select name="status" class="form-select">
                        <option value="">Tum Durumlar</option>
                        @if (statusOptions != null)
                        {
                            foreach (var item in statusOptions)
                            {
                                <option value="@item.Value" selected="@(item.Value == selectedStatus)">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                @if (!isHasta)
                {
                    <div class="col-12 col-md-3">
                        <label class="form-label">Doktor</label>
                        <select name="doctorId" class="form-select">
                            <option value="">Tum Doktorlar</option>
                            @if (doctorOptions != null)
                            {
                                foreach (var item in doctorOptions)
                                {
                                    <option value="@item.Value" selected="@(selectedDoctorId.HasValue && item.Value == selectedDoctorId.Value.ToString())">@item.Text</option>
                                }
                            }
                        </select>
                    </div>
                }

                <div class="col-12 col-md-3">
                    <label class="form-label">Baslangic</label>
                    <input type="date" name="fromDate" value="@fromDate" class="form-control" />
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label">Bitis</label>
                    <input type="date" name="toDate" value="@toDate" class="form-control" />
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Arama</label>
                    <input type="text" name="search" value="@searchTerm" class="form-control" placeholder="Hasta, doktor veya bolum" />
                </div>

                <div class="col-12">
                    <label class="form-label">Hizli tarih araligi</label>
                    <div class="d-flex flex-wrap gap-2">
                        <a asp-action="Index" asp-route-fromDate="@todayText" asp-route-toDate="@todayText" class="btn btn-outline-secondary btn-sm rounded-pill">Bugun</a>
                        <a asp-action="Index" asp-route-fromDate="@todayText" asp-route-toDate="@next7Text" class="btn btn-outline-secondary btn-sm rounded-pill">Sonraki 7 gun</a>
                        <a asp-action="Index" asp-route-fromDate="@todayText" asp-route-toDate="@next30Text" class="btn btn-outline-secondary btn-sm rounded-pill">Sonraki 30 gun</a>
                    </div>
                </div>

                <div class="col-12 col-md-6 d-flex gap-2 justify-content-end">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Filtrele</button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Temizle</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body py-5 text-center">
                <div class="text-muted mb-3"><i class="fa-regular fa-calendar-xmark fa-4x"></i></div>
                <h4>Kayıt bulunamadi.</h4>
            </div>
        </div>
    }
    else
    {
        <div class="d-md-none">
            @foreach (var item in Model)
            {
                var canPatientCancel = isHasta && item.AppointmentDate > DateTime.Now && item.Status != AppointmentStatus.Iptal && item.Status != AppointmentStatus.Tamamlandi;

                <div class="card shadow-sm mb-3 border-0 rounded-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                            <span class="fw-bold text-dark">@item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</span>
                            <span class="badge rounded-pill @(item.Status switch {
                                AppointmentStatus.Bekliyor => "bg-warning text-dark",
                                AppointmentStatus.Onaylandi => "bg-success",
                                AppointmentStatus.Iptal => "bg-danger",
                                _ => "bg-primary"
                            })">@item.Status</span>
                        </div>

                        <h5 class="card-title fw-bold text-primary">@item.Doctor?.Name @item.Doctor?.Surname</h5>
                        <p class="small text-muted mb-1">@item.Doctor?.Department?.Name</p>

                        <div class="d-grid gap-2 mt-3">
                            @if (isHasta)
                            {
                                if (canPatientCancel)
                                {
                                    <form asp-action="Cancel" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu randevuyu iptal etmek istiyor musunuz?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger rounded-pill w-100">Randevuyu Iptal Et</button>
                                    </form>
                                }
                            }
                            else
                            {
                                if (item.Status == AppointmentStatus.Bekliyor)
                                {
                                    <div class="btn-group w-100">
                                        <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success">Onayla</button>
                                        </form>
                                        <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu randevuyu reddetmek istiyor musunuz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger">Reddet</button>
                                        </form>
                                    </div>
                                }
                                else if (item.Status == AppointmentStatus.Onaylandi)
                                {
                                    <div class="btn-group w-100">
                                        <form asp-action="Complete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-primary">Tamamla</button>
                                        </form>
                                        <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu randevuyu iptal etmek istiyor musunuz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger">Iptal</button>
                                        </form>
                                    </div>
                                }
                                else
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu kaydi kalici olarak silmek istediginizden emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-secondary w-100">Sil</button>
                                    </form>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-none d-md-block">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-secondary">
                            <tr>
                                <th class="py-3 ps-4">Tarih</th>
                                @if (!isHasta)
                                {
                                    <th>Hasta</th>
                                }
                                <th>Doktor</th>
                                <th>Durum</th>
                                <th class="text-end pe-4">Islemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var canPatientCancel = isHasta && item.AppointmentDate > DateTime.Now && item.Status != AppointmentStatus.Iptal && item.Status != AppointmentStatus.Tamamlandi;

                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold d-block">@item.AppointmentDate.ToString("dd.MM.yyyy")</span>
                                        <span class="small text-muted">@item.AppointmentDate.ToString("HH:mm")</span>
                                    </td>
                                    @if (!isHasta)
                                    {
                                        <td>@item.PatientName @item.PatientSurname</td>
                                    }
                                    <td>
                                        <span class="fw-bold d-block">@item.Doctor?.Name @item.Doctor?.Surname</span>
                                        <span class="badge bg-light text-secondary border">@item.Doctor?.Department?.Name</span>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill @(item.Status switch {
                                            AppointmentStatus.Bekliyor => "bg-warning text-dark",
                                            AppointmentStatus.Onaylandi => "bg-success",
                                            AppointmentStatus.Iptal => "bg-danger",
                                            _ => "bg-primary"
                                        })">@item.Status</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (isHasta)
                                        {
                                            if (canPatientCancel)
                                            {
                                                <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu randevuyu iptal etmek istiyor musunuz?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill">Iptal Et</button>
                                                </form>
                                            }
                                        }
                                        else
                                        {
                                            if (item.Status == AppointmentStatus.Bekliyor)
                                            {
                                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-success" title="Onayla"><i class="fa-solid fa-check"></i></button>
                                                </form>
                                                <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu randevuyu reddetmek istiyor musunuz?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Reddet"><i class="fa-solid fa-xmark"></i></button>
                                                </form>
                                            }
                                            else if (item.Status == AppointmentStatus.Onaylandi)
                                            {
                                                <form asp-action="Complete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-primary" title="Tamamla"><i class="fa-solid fa-clipboard-check"></i></button>
                                                </form>
                                                <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu randevuyu iptal etmek istiyor musunuz?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Iptal"><i class="fa-solid fa-ban"></i></button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu kaydi silmek istediginizden emin misiniz?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-light text-danger" title="Sil"><i class="fa-solid fa-trash-can"></i></button>
                                                </form>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
