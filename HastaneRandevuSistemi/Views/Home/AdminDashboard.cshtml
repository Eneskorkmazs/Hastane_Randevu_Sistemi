@model HastaneRandevuSistemi.Models.DashboardViewModel

@{
    ViewData["Title"] = "Yönetim Merkezi";
}

<div class="container-fluid px-md-5 py-4">
    @* ÜST BİLGİ: PC'de yan yana, Mobilde merkezli *@
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5 border-bottom pb-4">
        <div class="mb-3 mb-md-0">
            <h6 class="text-primary fw-bold text-uppercase ls-2 small mb-1">Sistem Genel Bakış</h6>
            <h1 class="display-5 fw-bold text-dark mb-0">Yönetim Merkezi</h1>
        </div>
        <div class="text-md-end">
            <span class="badge bg-white text-dark border px-4 py-2 rounded-pill shadow-sm">
                <i class="fa-solid fa-clock me-2 text-primary"></i>@DateTime.Now.ToString("dd MMMM yyyy")
            </span>
        </div>
    </div>

    <div class="row g-4">
        @* SOL: İSTATİSTİK KOLONU (PC'de Dik, Mobilde Yan Yana) *@
        <div class="col-12 col-xl-3">
            <div class="row g-3 flex-xl-column">
                <div class="col-12 col-sm-4 col-xl-12">
                    <div class="admin-stat-card bg-white p-4 shadow-sm rounded-4 d-flex align-items-center justify-content-between h-100">
                        <div>
                            <p class="text-muted x-small fw-bold mb-1">DOKTORLAR</p>
                            <h2 class="fw-bold mb-0">@Model.TotalDoctors</h2>
                        </div>
                        <div class="stat-icon bg-primary-soft text-primary"><i class="fa-solid fa-user-md fs-4"></i></div>
                    </div>
                </div>
                <div class="col-12 col-sm-4 col-xl-12">
                    <div class="admin-stat-card bg-white p-4 shadow-sm rounded-4 d-flex align-items-center justify-content-between h-100">
                        <div>
                            <p class="text-muted x-small fw-bold mb-1">BRANŞLAR</p>
                            <h2 class="fw-bold mb-0">@Model.TotalDepartments</h2>
                        </div>
                        <div class="stat-icon bg-success-soft text-success"><i class="fa-solid fa-hospital fs-4"></i></div>
                    </div>
                </div>
                <div class="col-12 col-sm-4 col-xl-12">
                    <div class="admin-stat-card bg-white p-4 shadow-sm rounded-4 d-flex align-items-center justify-content-between h-100">
                        <div>
                            <p class="text-muted x-small fw-bold mb-1">RANDEVULAR</p>
                            <h2 class="fw-bold mb-0">@Model.TotalAppointments</h2>
                        </div>
                        <div class="stat-icon bg-info-soft text-info"><i class="fa-solid fa-chart-line fs-4"></i></div>
                    </div>
                </div>
            </div>
        </div>

        @* SAĞ: ANA PANELLER *@
        <div class="col-12 col-xl-9">
            <div class="row g-4">
                @* BEKLEYEN ONAYLAR: Desktop'ta dev gibi, Mobilde tam ekran *@
                <div class="col-12 col-lg-8">
                    <div class="card border-0 shadow-lg rounded-5 h-100 overflow-hidden text-white main-gradient position-relative">
                        <div class="card-body p-4 p-md-5 z-1 position-relative">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <h3 class="fw-bold">Bekleyen Onaylar</h3>
                                <span class="badge bg-danger pulse-animation px-3 py-2 rounded-pill shadow">KRİTİK DURUM</span>
                            </div>
                            <h1 class="display-1 fw-bold mb-3 mt-4">@Model.PendingAppointments</h1>
                            <p class="opacity-75 fs-5 mb-5 d-none d-md-block">Bekleyen randevu taleplerini onaylayarak sistem akışını hızlandırın.</p>
                            <a asp-controller="Appointment" asp-action="Index" class="btn btn-info btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg mt-2">
                                <i class="fa-solid fa-arrow-right-long me-2"></i>Hemen Yönet
                            </a>
                        </div>
                    </div>
                </div>

                @* BUGÜNÜN ÖZETİ *@
                <div class="col-12 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-5 h-100 bg-white border-top border-primary border-5">
                        <div class="card-body p-4 p-md-5 text-center d-flex flex-column justify-content-center">
                            <div class="bg-light rounded-circle mx-auto mb-4 d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                <i class="fa-solid fa-calendar-day fa-3x text-primary"></i>
                            </div>
                            <h2 class="fw-bold text-dark mb-1">Bugün</h2>
                            <p class="text-muted small text-uppercase ls-1">Aktif Program</p>
                            <h1 class="display-3 fw-bold text-primary">@Model.TodaysAppointments</h1>
                        </div>
                    </div>
                </div>

                @* HIZLI İŞLEMLER ÇUBUĞU *@
                <div class="col-12">
                    <div class="bg-white p-4 rounded-4 shadow-sm border d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
                        <div class="d-flex align-items-center">
                            <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-3">
                                <i class="fa-solid fa-bolt text-warning fs-4"></i>
                            </div>
                            <h5 class="fw-bold mb-0">Hızlı Erişim Kanalları</h5>
                        </div>
                        <div class="d-flex flex-wrap justify-content-center gap-2">
                            <a asp-controller="Doctor" asp-action="Create" class="btn btn-outline-dark rounded-pill fw-bold px-4">Doktor Ekle</a>
                            <a asp-controller="Department" asp-action="Create" class="btn btn-outline-dark rounded-pill fw-bold px-4">Bölüm Ekle</a>
                            <a asp-controller="Appointment" asp-action="Create" class="btn btn-primary rounded-pill fw-bold px-4 shadow-sm">Yeni Randevu</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>