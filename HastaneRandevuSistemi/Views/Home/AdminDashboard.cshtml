@model HastaneRandevuSistemi.Models.DashboardViewModel

@{
    ViewData["Title"] = "Yönetim Merkezi";
}

<div class="container-fluid px-md-5 py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5 border-bottom pb-4">
        <div class="mb-3 mb-md-0">
            <h6 class="text-primary fw-bold text-uppercase ls-2 small mb-1">Sistem Genel Bakýţ</h6>
            <h1 class="display-5 fw-bold text-dark mb-0">Yönetim Merkezi</h1>
        </div>
        <div class="text-md-end">
            <span class="badge bg-white text-dark border px-4 py-2 rounded-pill shadow-sm">
                <i class="fa-solid fa-clock me-2 text-primary"></i>@DateTime.Now.ToString("dd MMMM yyyy")
            </span>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="admin-stat-card bg-white p-4 shadow-sm rounded-4 d-flex align-items-center justify-content-between h-100">
                <div>
                    <p class="text-muted x-small fw-bold mb-1">DOKTORLAR</p>
                    <h2 class="fw-bold mb-0">@Model.TotalDoctors</h2>
                </div>
                <div class="stat-icon bg-primary-soft text-primary"><i class="fa-solid fa-user-md fs-4"></i></div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="admin-stat-card bg-white p-4 shadow-sm rounded-4 d-flex align-items-center justify-content-between h-100">
                <div>
                    <p class="text-muted x-small fw-bold mb-1">BRANŢLAR</p>
                    <h2 class="fw-bold mb-0">@Model.TotalDepartments</h2>
                </div>
                <div class="stat-icon bg-success-soft text-success"><i class="fa-solid fa-hospital fs-4"></i></div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="admin-stat-card bg-white p-4 shadow-sm rounded-4 d-flex align-items-center justify-content-between h-100">
                <div>
                    <p class="text-muted x-small fw-bold mb-1">BUGÜN</p>
                    <h2 class="fw-bold mb-0">@Model.TodaysAppointments</h2>
                </div>
                <div class="stat-icon bg-info-soft text-info"><i class="fa-solid fa-calendar-day fs-4"></i></div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="admin-stat-card bg-white p-4 shadow-sm rounded-4 d-flex align-items-center justify-content-between h-100">
                <div>
                    <p class="text-muted x-small fw-bold mb-1">BU HAFTA</p>
                    <h2 class="fw-bold mb-0">@Model.ThisWeekAppointments</h2>
                </div>
                <div class="stat-icon bg-warning-soft text-warning"><i class="fa-solid fa-calendar-week fs-4"></i></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-5 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold">Durum Özeti</h5>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>Toplam</span>
                        <strong>@Model.TotalAppointments</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>Bekleyen</span>
                        <strong class="text-warning">@Model.PendingAppointments</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>Onaylanan</span>
                        <strong class="text-success">@Model.ApprovedAppointments</strong>
                    </div>
                    <div class="d-flex justify-content-between py-2">
                        <span>Tamamlanan</span>
                        <strong class="text-primary">@Model.CompletedAppointments</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0">Son Bildirimler</h5>
                    </div>

                    @if (!Model.LatestNotifications.Any())
                    {
                        <div class="text-muted">Henüz sistem bildirimi bulunmuyor.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var item in Model.LatestNotifications)
                            {
                                <div class="list-group-item px-0 py-3 d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="d-flex gap-2 align-items-center">
                                            <span class="badge bg-light text-dark border">@item.Type</span>
                                            <strong>@item.Title</strong>
                                        </div>
                                        <p class="mb-1 text-muted small">@item.Message</p>
                                        <small class="text-secondary">@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</small>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.Link))
                                    {
                                        <a href="@item.Link" class="btn btn-sm btn-light rounded-pill">Git</a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="bg-white p-4 rounded-4 shadow-sm border d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
                <div class="d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-3">
                        <i class="fa-solid fa-bolt text-warning fs-4"></i>
                    </div>
                    <h5 class="fw-bold mb-0">Hýzlý Eriţim</h5>
                </div>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <a asp-controller="Doctor" asp-action="Create" class="btn btn-outline-dark rounded-pill fw-bold px-4">Doktor Ekle</a>
                    <a asp-controller="Department" asp-action="Create" class="btn btn-outline-dark rounded-pill fw-bold px-4">Bölüm Ekle</a>
                    <a asp-controller="Appointment" asp-action="Create" class="btn btn-primary rounded-pill fw-bold px-4 shadow-sm">Yeni Randevu</a>
                </div>
            </div>
        </div>
    </div>
</div>
