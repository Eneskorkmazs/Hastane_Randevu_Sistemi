@model HastaneRandevuSistemi.Models.DashboardViewModel

@{
    ViewData["Title"] = "Doktor Paneli";
}

<div class="container mt-4">
    @* ÜST KARŞILAMA ALANI: Modern Gradient ve Cam Efekti *@
    <div class="p-5 mb-5 text-white rounded-5 shadow-lg position-relative overflow-hidden"
         style="background: linear-gradient(135deg, #004e92 0%, #000428 100%);">
        <div class="position-relative z-1">
            <h1 class="display-5 fw-bold mb-2">
                <i class="fa-solid fa-hand-holding-medical me-3 text-info"></i>Hoş Geldiniz, Sayın Doktorumuz
            </h1>
            <p class="fs-5 opacity-75">Bugünkü randevu trafiğiniz ve genel özet bilgileriniz aşağıda listelenmiştir.</p>
        </div>
        @* Arka plan dekoratif ikon *@
        <i class="fa-solid fa-stethoscope position-absolute end-0 bottom-0 mb-n4 me-n2 opacity-25" style="font-size: 15rem;"></i>
    </div>

    @* İSTATİSTİK KARTLARI *@
    <div class="row g-4">
        @* Bugünkü Randevular *@
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100 hover-grow">
                <div class="card-body p-4 text-center">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 70px; height: 70px;">
                        <i class="fa-solid fa-calendar-check fa-2x text-primary"></i>
                    </div>
                    <h6 class="text-secondary text-uppercase fw-bold ls-1 small mb-3">Bugünkü Randevular</h6>
                    <h1 class="display-3 fw-black text-dark mb-0">@Model.TodaysAppointments</h1>
                    <div class="mt-2 small text-success">
                        <i class="fa-solid fa-arrow-up me-1"></i> Güncel Durum
                    </div>
                </div>
            </div>
        </div>

        @* Onay Bekleyen *@
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100 hover-grow">
                <div class="card-body p-4 text-center">
                    <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 70px; height: 70px;">
                        <i class="fa-solid fa-hourglass-half fa-2x text-warning"></i>
                    </div>
                    <h6 class="text-secondary text-uppercase fw-bold ls-1 small mb-3">Onay Bekleyenler</h6>
                    <h1 class="display-3 fw-black text-dark mb-0">@Model.PendingAppointments</h1>
                    <div class="mt-2 small text-muted">Aksiyon Bekliyor</div>
                </div>
            </div>
        </div>

        @* Toplam Hasta *@
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4 h-100 hover-grow">
                <div class="card-body p-4 text-center">
                    <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 70px; height: 70px;">
                        <i class="fa-solid fa-users-viewfinder fa-2x text-success"></i>
                    </div>
                    <h6 class="text-secondary text-uppercase fw-bold ls-1 small mb-3">Toplam Kayıtlı Hasta</h6>
                    <h1 class="display-3 fw-black text-dark mb-0">@Model.TotalAppointments</h1>
                    <div class="mt-2 small text-muted">Genel Toplam</div>
                </div>
            </div>
        </div>
    </div>

    @* AKSİYON BUTONU *@
    <div class="mt-5">
        <a asp-controller="Appointment" asp-action="Index"
           class="btn btn-primary btn-lg rounded-pill py-3 px-5 shadow-lg fw-bold border-0 hover-lift w-100"
           style="background: linear-gradient(90deg, #004e92 0%, #000428 100%);">
            <i class="fa-solid fa-notes-medical me-2"></i> Randevu Takvimini Görüntüle ve Yönet
        </a>
    </div>

