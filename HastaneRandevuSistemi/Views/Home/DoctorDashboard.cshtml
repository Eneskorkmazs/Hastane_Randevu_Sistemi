@model HastaneRandevuSistemi.Models.DashboardViewModel

@{
    ViewData["Title"] = "Doktor Paneli";
    var upcoming = Model.UpcomingAppointments ?? Array.Empty<HastaneRandevuSistemi.Models.Appointment>();
}

<div class="container mt-4">
    <div class="p-5 mb-5 text-white rounded-5 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #004e92 0%, #000428 100%);">
        <div class="position-relative z-1">
            <h1 class="display-5 fw-bold mb-2">
                <i class="fa-solid fa-hand-holding-medical me-3 text-info"></i>Hoş Geldiniz, Sayın Doktorumuz
            </h1>
            <p class="fs-5 opacity-75">Bugünkü ve haftalık özetiniz ile yaklaşılan randevularınızı takip edin.</p>
        </div>
        <i class="fa-solid fa-stethoscope position-absolute end-0 bottom-0 mb-n4 me-n2 opacity-25" style="font-size: 15rem;"></i>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h6 class="text-secondary text-uppercase fw-bold ls-1 small mb-3">Bugünkü Randevular</h6>
                    <h1 class="display-4 fw-black text-dark mb-0">@Model.TodaysAppointments</h1>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h6 class="text-secondary text-uppercase fw-bold ls-1 small mb-3">Bu Haftaki Randevular</h6>
                    <h1 class="display-4 fw-black text-dark mb-0">@Model.ThisWeekAppointments</h1>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h6 class="text-secondary text-uppercase fw-bold ls-1 small mb-3">Onaylanan</h6>
                    <h1 class="display-4 fw-black text-dark mb-0">@Model.ApprovedAppointments</h1>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <h6 class="text-secondary text-uppercase fw-bold ls-1 small mb-3">Tamamlanan</h6>
                    <h1 class="display-4 fw-black text-dark mb-0">@Model.CompletedAppointments</h1>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column flex-md-row gap-3 justify-content-between align-items-md-end mt-5 mb-3">
        <div>
            <h3 class="fw-bold mb-1">Yaklaşan Randevular</h3>
            <p class="text-muted mb-0">Yaklaşan en fazla 6 randevunuz filtrelenerek listelenir.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Appointment" asp-action="Index" asp-route-status="@( (int)AppointmentStatus.Bekliyor )" class="btn btn-outline-warning rounded-pill px-4">Bekleyenler</a>
            <a asp-controller="Appointment" asp-action="Index" asp-route-status="@( (int)AppointmentStatus.Onaylandi )" class="btn btn-outline-success rounded-pill px-4">Onaylı</a>
            <a asp-controller="Appointment" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">Tümü</a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="py-3 ps-4">Tarih / Saat</th>
                        <th>Hasta</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!upcoming.Any())
                    {
                        <tr>
                            <td class="ps-4 py-4 text-muted" colspan="4">Yaklaşan randevu bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in upcoming)
                        {
                            <tr>
                                <td class="ps-4">@item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@item.PatientName @item.PatientSurname</td>
                                <td>
                                    <span class="badge rounded-pill @(item.Status == AppointmentStatus.Bekliyor ? "bg-warning text-dark" : item.Status == AppointmentStatus.Onaylandi ? "bg-success" : item.Status == AppointmentStatus.Tamamlandi ? "bg-info" : "bg-danger")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    @if (item.Status == AppointmentStatus.Bekliyor)
                                    {
                                        <form asp-controller="Appointment" asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">Onayla</button>
                                        </form>
                                    }
                                    else if (item.Status == AppointmentStatus.Onaylandi)
                                    {
                                        <form asp-controller="Appointment" asp-action="Complete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-primary">Tamamla</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-5">
        <a asp-controller="Appointment" asp-action="Index" class="btn btn-primary btn-lg rounded-pill py-3 px-5 shadow-lg fw-bold border-0 hover-lift w-100" style="background: linear-gradient(90deg, #004e92 0%, #000428 100%);">
            <i class="fa-solid fa-notes-medical me-2"></i> Tüm Randevuları Gör ve Yönet
        </a>
    </div>
</div>
