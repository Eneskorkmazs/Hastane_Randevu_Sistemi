@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header text-white text-center py-4" style="background: linear-gradient(90deg, #004e92 0%, #000428 100%);">
                <div class="mb-2"><i class="fa-solid fa-circle-question fa-3x"></i></div>
                <h4 class="fw-bold mb-0">Şifremi Unuttum</h4>
                <small class="text-white-50">Email adresinize sıfırlama linki göndereceğiz.</small>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="ForgotPassword" method="post">
                    <div class="form-floating mb-4">
                        <input name="email" type="email" class="form-control rounded-pill px-4" placeholder="Email" required />
                        <label class="px-4"><i class="fa-solid fa-envelope me-2 text-primary"></i>Kayıtlı Email Adresi</label>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold shadow-sm" style="background: linear-gradient(90deg, #004e92 0%, #000428 100%); border:none;">
                            <i class="fa-solid fa-paper-plane me-2"></i> Linki Gönder
                        </button>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3 border-0">
                <a asp-action="Login" class="text-decoration-none fw-bold text-secondary"><i class="fa-solid fa-arrow-left me-1"></i> Girişe Dön</a>
            </div>
        </div>
    </div>
</div>