@{
    ViewData["Title"] = "Şifre Güncellendi";
}

<div class="row justify-content-center mt-5 pt-5">
    <div class="col-md-6 text-center">
        <div class="card shadow-lg border-0 rounded-4 p-5">
            <div class="mb-4 text-primary"><i class="fa-solid fa-circle-check fa-5x"></i></div>
            <h2 class="fw-bold text-primary">Tebrikler!</h2>
            <p class="lead text-muted mt-3">Şifreniz başarıyla güncellendi. Artık yeni şifrenizle giriş yapabilirsiniz.</p>
            <div class="mt-4">
                <a asp-action="Login" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                    <i class="fa-solid fa-right-to-bracket me-2"></i> Giriş Yap
                </a>
            </div>
        </div>
    </div>
</div>