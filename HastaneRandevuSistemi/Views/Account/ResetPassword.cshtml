@model HastaneRandevuSistemi.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

            <div class="card-header text-white text-center py-4" style="background: linear-gradient(90deg, #004e92 0%, #000428 100%);">
                <div class="mb-2"><i class="fa-solid fa-key fa-3x"></i></div>
                <h4 class="fw-bold mb-0">Yeni Şifre Belirle</h4>
            </div>

            <div class="card-body p-4">
                <form asp-action="ResetPassword" method="post">

                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="Email" />

                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control rounded-pill px-4" placeholder="Yeni Şifre" />
                        <label asp-for="Password" class="px-4">Yeni Şifre</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" type="password" class="form-control rounded-pill px-4" placeholder="Şifre Tekrar" />
                        <label asp-for="ConfirmPassword" class="px-4">Şifre Tekrar</label>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success btn-lg rounded-pill fw-bold" style="background: linear-gradient(90deg, #004e92 0%, #000428 100%); border:none;">
                            <i class="fa-solid fa-check me-2"></i> Şifreyi Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>