@{
    ViewData["Title"] = "Mail Gönderildi";
}

<div class="row justify-content-center mt-5 pt-5">
    <div class="col-md-6 text-center">
        <div class="card shadow-lg border-0 rounded-4 p-5">
            <div class="mb-4 text-success"><i class="fa-regular fa-envelope-open fa-5x"></i></div>
            <h2 class="fw-bold text-success">Mail Gönderildi!</h2>
            <p class="lead text-muted mt-3">Lütfen gelen kutunuzu (ve spam klasörünü) kontrol edin. Şifre sıfırlama talimatlarını içeren bir e-posta gönderdik.</p>
            <div class="mt-4">
                <a asp-action="Login" class="btn btn-outline-primary rounded-pill px-4">Giriş Sayfasına Dön</a>
            </div>
        </div>
    </div>
</div>